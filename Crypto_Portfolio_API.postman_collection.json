            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bitcoin\",\n  \"symbol\": \"BTC\",\n  \"coinGeckoId\": \"bitcoin\",\n  \"description\": \"Digital gold\",\n  \"riskPercentage\": 45.0\n}"
            },
            "url": {"raw": "http://localhost:8080/api/assets"}
          }
        },
